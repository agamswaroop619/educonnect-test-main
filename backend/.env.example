# ---------------------------------------------------------------------------
# Database
# Async PostgreSQL connection string used by SQLAlchemy + asyncpg.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/scholarly_db

# ---------------------------------------------------------------------------
# JWT Secrets
# Use a cryptographically random 256-bit (32-byte) string for each secret.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# JWT_SECRET signs short-lived access tokens (15 min TTL).
# JWT_REFRESH_SECRET signs long-lived refresh tokens (7 day TTL).
# ---------------------------------------------------------------------------
JWT_SECRET=change_me_to_a_random_256_bit_secret
JWT_REFRESH_SECRET=change_me_to_another_random_256_bit_secret

# ---------------------------------------------------------------------------
# CORS
# Comma-separated list of allowed frontend origins.
# Example for local development with Vite and TanStack Start:
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------------------------
# AWS / Cloudflare R2 Object Storage
# Used for gallery photo uploads and homework file attachments.
# Leave AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY empty if not using S3/R2.
# S3_ENDPOINT_URL should point to your R2 endpoint or omit for AWS S3.
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=scholarly-uploads
S3_ENDPOINT_URL=https://your-r2-endpoint.r2.cloudflarestorage.com

# ---------------------------------------------------------------------------
# Application Metadata
# APP_VERSION is returned by the GET /api/v1/health endpoint.
# ---------------------------------------------------------------------------
APP_VERSION=0.1.0

# ---------------------------------------------------------------------------
# Library Fine Rate
# Daily fine (in currency units) charged per overdue library book.
# Used by library_service.return_book() to compute fines dynamically.
# ---------------------------------------------------------------------------
DAILY_LIBRARY_FINE_RATE=2.00

# ---------------------------------------------------------------------------
# AI Assistant Provider
# AI_PROVIDER_API_KEY: API key for the configured AI provider.
# AI_PROVIDER_BASE_URL: Base URL for the AI completions endpoint.
#   Defaults to OpenAI; override for Azure OpenAI, Groq, etc.
# AI_MODEL: Model identifier to use for chat completions.
# ---------------------------------------------------------------------------
AI_PROVIDER_API_KEY=
AI_PROVIDER_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
